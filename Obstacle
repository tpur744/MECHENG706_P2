void loop() {
  updateGyro();
  updateIR();

  float dist = getDistance();
  bool leftIR = (frontLeftAvg > FRONT_IR_OBSTACLE_THRESHOLD);
  bool rightIR = (frontRightAvg > FRONT_IR_OBSTACLE_THRESHOLD);
  bool ultrasonicClose = (dist < 15.0);

  static int obstacleSide = 0;
  if      (leftIR && !rightIR)  obstacleSide = -1;
  else if (rightIR && !leftIR)  obstacleSide =  1;
  else if (leftIR && rightIR)   obstacleSide =  0;
  else if (!leftIR && !rightIR) obstacleSide =  0;

  bool obstacleDetected = leftIR || rightIR || ultrasonicClose;

  // ── Servo sweep / track ───────────────────────────────────────────
  unsigned long now = millis();
  if (now - lastServoTime >= (obstacleDetected ? servoDelay / 4 : servoDelay)) {
    lastServoTime = now;

    if (obstacleDetected && obstacleSide != 0) {
      // Jump directly to the obstacle side
      servoAngle = (obstacleSide == -1)
                 ? centreAngle + offsetAngle   // snap hard left
                 : centreAngle - offsetAngle;  // snap hard right
      // Update direction so sweep resumes correctly after clearing
      servoDirection = (obstacleSide == -1) ? -1 : +1;
    } else if (obstacleDetected && obstacleSide == 0) {
      // Both IR triggered — hold position
    } else {
      // No obstacle — sweep normally
      servoAngle += servoDirection * servoStep;
      if (servoAngle <= centreAngle - offsetAngle) {
        servoAngle     = centreAngle - offsetAngle;
        servoDirection = +1;
      } else if (servoAngle >= centreAngle + offsetAngle) {
        servoAngle     = centreAngle + offsetAngle;
        servoDirection = -1;
      }
    }

    scanServo.write(servoAngle);
  }

   // ── Strafe Decision Logic ───────────────────────────────────────
  String movementCommand = "FORWARD";

  if (obstacleDetected) {
    // Left side blocked → move right
    if (obstacleSide == -1) {
      movementCommand = "STRAFE RIGHT";
    }
    // Right side blocked → move left
    else if (obstacleSide == 1) {
      movementCommand = "STRAFE LEFT";
    }
    // Both blocked
    else {
      // Very close object ahead
      if (ultrasonicClose) {
        movementCommand = "REVERSE";
      }
      else {
        // Compare IR strengths to pick clearer side
        if (frontLeftAvg > frontRightAvg) {
          movementCommand = "STRAFE RIGHT";
        }
        else if (frontRightAvg > frontLeftAvg) {
          movementCommand = "STRAFE LEFT";
        }
        else {
          movementCommand = "STOP";
        }
      }
    }
  }

  // ── Print ─────────────────────────────────────────────────────────
  Serial.print("Servo: ");        Serial.print(servoAngle);
  Serial.print("  Mode: ");
  if      (!obstacleDetected)  Serial.print("SWEEPING   ");
  else if (obstacleSide ==  0) Serial.print("HOLD       ");
  else if (obstacleSide == -1) Serial.print("SNAP LEFT  ");
  else                         Serial.print("SNAP RIGHT ");
  Serial.print("  Dist: ");      Serial.print(dist);
  Serial.print("cm  L_IR: ");    Serial.print(frontLeftAvg);
  Serial.print("  R_IR: ");      Serial.print(frontRightAvg);
  Serial.print("  ObstacleSide: ");
  if      (obstacleSide == -1) Serial.print("LEFT ");
  else if (obstacleSide ==  1) Serial.print("RIGHT");
  else                         Serial.print("NONE ");
  Serial.print("  >> ");
  Serial.println(obstacleDetected ? "OBSTACLE" : "CLEAR");
  Serial.print("  Move: ");
  Serial.print(movementCommand);

  delay(20);
}

