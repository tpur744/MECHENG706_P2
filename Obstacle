void doStrafe() {
  updateGyro();
  updateIR();

  unsigned long now = millis();
  bool leftIR  = (frontLeftAvg  > FRONT_IR_OBSTACLE_THRESHOLD);
  bool rightIR = (frontRightAvg > FRONT_IR_OBSTACLE_THRESHOLD);
  float dist   = getDistance();
  bool ultrasonicClose = (dist < 15.0);
  bool obstacleDetected = leftIR || rightIR || ultrasonicClose;

  // ── Phase 3: forward burst after clearing ────────────────────────
  if (state == STRAFE_FORWARD) {
    if (now - strafe.forwardStart >= STRAFE_FORWARD_BURST_MS) {
      stopMotors(); delay(200);
      rescan.sweepBestSum     = 0;
      rescan.sweepBestHeading = bestDriveHeading;
      float diff = wrapAngle(bestDriveHeading - heading);
      rescan.sweepDir   = (diff >= 0) ? 1 : -1;
      rescan.sweepStart = heading;
      pidForward.reset(); pidStrafeR.reset(); pidStrafeL.reset();
      state = RESCAN_SWEEP;
    } else {
      move(speedVal, 0, (int)pidForward.compute(wrapAngle(bestDriveHeading - heading)));
    }
    return;
  }

  // ── Active strafing — keep going until obstacle clears ───────────
  if (!obstacleDetected) {
    // Obstacle clear — short coast then forward burst
    if (state != STRAFE_COAST) {
      strafe.coastStart = now;
      state = STRAFE_COAST;
    }
  }

  if (state == STRAFE_COAST) {
    if (obstacleDetected) {
      // Obstacle came back — resume strafing
      state = STRAFING;
    } else if (now - strafe.coastStart >= POST_STRAFE_COAST_MS) {
      stopMotors(); delay(100);
      strafe.forwardStart = millis();
      state = STRAFE_FORWARD;
      return;
    }
    // Keep moving sideways during coast
    int correction = (strafe.dir > 0)
      ? (int)pidStrafeR.compute(wrapAngle(strafe.targetHeading - heading))
      : (int)pidStrafeL.compute(wrapAngle(strafe.targetHeading - heading));
    move(0, strafe.dir * speedVal, correction);
    return;
  }

  // Still obstructed — keep strafing
  Serial.print("Strafing... L_IR="); Serial.print(frontLeftAvg);
  Serial.print(" R_IR=");            Serial.print(frontRightAvg);
  Serial.print(" Dist=");            Serial.println(dist);

  int correction = (strafe.dir > 0)
    ? (int)pidStrafeR.compute(wrapAngle(strafe.targetHeading - heading))
    : (int)pidStrafeL.compute(wrapAngle(strafe.targetHeading - heading));
  move(0, strafe.dir * speedVal, correction);
}
// =====================================================
// RESCAN — ±60° sweep then rotate to best heading
// =====================================================
void doRescan() {
  updateGyro();

  if (state == RESCAN_ROTATE) {
    if (rotateToHeading(rescan.sweepBestHeading)) {
      bestHeading = bestDriveHeading = rescan.sweepBestHeading;
      bestDriveSum = 0;
      servoLocked = false;
      scanServo.write(centreAngle);
      servoAngle = centreAngle + offsetAngle;
      servoDirection = -1;
      state = DRIVING;
    }
    return;
  }

  // RESCAN_SWEEP — track cumulative signed rotation from sweep start
  float rotated = wrapAngle(heading - rescan.sweepStart);
  int sum = analogRead(sensor1) + analogRead(sensor2)
            + analogRead(sensor3) + analogRead(sensor4);

  if (sum > rescan.sweepBestSum) {
    rescan.sweepBestSum = sum;
    rescan.sweepBestHeading = heading;
  }

  LED_Number(2000, sum);
  plotSensors();

  // sweepDir: +1 means we rotate positive (CCW), -1 means CW
  // Check if we've swept the full ±sweepRange in our direction
  float signedRotated = rotated * rescan.sweepDir;  // positive when moving in intended dir
  if (signedRotated >= sweepRange) {
    stopMotors();
    delay(100);
    state = RESCAN_ROTATE;
    return;
  }

  // Fix: match sign to your move() convention
  // Positive sweepDir = rotate CCW = negative rotate param (or positive, test this)
  move(0, 0, -rescan.sweepDir * 150);
  delay(20);
}

// =====================================================
// TRIGGER STRAFE
// =====================================================
void triggerStrafe() {
  float leftDist = getLeftDistance();
  float rightDist = getRightDistance();
  Serial.print("Obstacle! L=");
  Serial.print(leftDist);
  Serial.print("cm  R=");
  Serial.println(rightDist);

  strafe.dir = (leftDist > rightDist) ? -1 : 1;
  strafe.targetHeading = heading;
  strafe.startTime = millis();

  pidStrafeR.reset();
  pidStrafeL.reset();
  stopMotors();
  delay(100);
  state = STRAFING;
}

// =====================================================
// 360° SCAN
// =====================================================
void scanForLight() {
  int rotateSpeed = 220;
  bestSum = 0;
  bestHeading = heading;

  float lastHeading = heading, totalRotated = 0.0;
  unsigned long scanStart = millis();

  while (totalRotated < 2 * PI) {
    updateGyro();
    if (millis() - scanStart > 6000) {
      Serial.println("SCAN TIMEOUT");
      break;
    }
    if (totalRotated > (330.0 * PI / 180.0)) rotateSpeed = 80;

    move(0, 0, -rotateSpeed);

    int sum = analogRead(sensor1) + analogRead(sensor2)
              + analogRead(sensor3) + analogRead(sensor4);
    LED_Number(2000, sum);

    if (sum > bestSum) {
      bestSum = sum;
      bestHeading = heading;
    }

    plotSensors();

    float delta = wrapAngle(heading - lastHeading);
    if (abs(delta) > 0.001) totalRotated += abs(delta);
    lastHeading = heading;
    delay(20);
  }

  stopMotors();
  bestHeading = wrapAngle(bestHeading);
}

// =====================================================
// ROTATE TO HEADING
// =====================================================
bool rotateToHeading(float target) {
  updateGyro();
  float err = wrapAngle(target - heading);

  plotSensors();
  LED_Number(0.1, abs(err));

  if (abs(err) < (3.0 * PI / 180.0)) {
    stopMotors();
    return true;
  }

  int rotateSpeed = (abs(err) > (30.0 * PI / 180.0)) ? 250 : 100;
  move(0, 0, -(err > 0 ? 1 : -1) * rotateSpeed);
  delay(20);
  return false;
}

// =====================================================
// DRIVE FORWARD
// =====================================================
void driveForward() {
  updateGyro();

  float dist = getDistance();
  int angleFromCentre = servoAngle - centreAngle;

  // Servo scan / lock
  if (!servoLocked && dist < 30.0 && abs(angleFromCentre) < 3) {
    servoLocked = true;
    scanServo.write(centreAngle);
  }
  if (!servoLocked) {
    unsigned long now = millis();
    if (now - lastServoTime >= servoDelay) {
      lastServoTime = now;
      servoAngle += servoDirection * servoStep;
      if (servoAngle <= centreAngle - offsetAngle) {
        servoAngle = centreAngle - offsetAngle;
        servoDirection = +1;
      } else if (servoAngle >= centreAngle + offsetAngle) {
        servoAngle = centreAngle + offsetAngle;
        servoDirection = -1;
      }
      scanServo.write(servoAngle);
    }
  }



  // LED indicators
  int thr = 900;
  if (analogRead(sensor1) > thr) {
    LED("on", "orange");
  } else LED("off", "orange");
  if (analogRead(sensor1) > thr) {
    LED("on", "green");
  } else LED("off", "green");
  if (analogRead(sensor1) > thr) {
    LED("on", "blue");
  } else LED("off", "blue");
  if (analogRead(sensor1) > thr) {
    LED("on", "red");
  } else LED("off", "red");

  // Obstacle check
  int maxSensor = max(max(analogRead(sensor1), analogRead(sensor2)),
                      max(analogRead(sensor3), analogRead(sensor4)));
  bool lightInView = (maxSensor > thr);
  bool frontIRClose = frontIRObstacleDetected();
  bool ultrasonicClose = (dist < 15.0);

  if ((ultrasonicClose || frontIRClose) && !lightInView) {
    triggerStrafe();
    return;
  }

  // Update best drive heading via servo offset
  int sum = analogRead(sensor1) + analogRead(sensor2)
            + analogRead(sensor3) + analogRead(sensor4);
  if (sum > bestDriveSum) {
    bestDriveSum = sum;
    float offsetRad = (servoAngle - centreAngle) * (PI / 180.0);
    bestDriveHeading = wrapAngle(heading + offsetRad);
  }
  bestDriveSum = bestDriveSum * 0.995;

  move(200, 0, (int)pidForward.compute(wrapAngle(bestDriveHeading - heading)));
  plotSensors();

  // Final stop
  if (dist < 15.0 && lightInView) {
    stopMotors();
    unsigned long t = millis();
    while (millis() - t < 3000) digitalWrite(fanPin, HIGH);
    digitalWrite(fanPin, LOW);
    lightsFound++;
    if (lightsFound >= totalLights) {
      state = DONE;
      return;
    }
    delay(5000);
    reverseStartTime = millis();
    state = REVERSING;
    return;
  }
}
